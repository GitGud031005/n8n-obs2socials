    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Confirm & Approve OBS Recording</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --bg-gradient: linear-gradient(135deg, #0b0813 0%, #110c24 50%, #1a0f35 100%);\n            --card-bg: rgba(255, 255, 255, 0.03);\n            --card-border: rgba(255, 255, 255, 0.08);\n            --text-primary: #f3f1f6;\n            --text-secondary: #a5a1b8;\n            --accent-primary: #8a2be2;\n            --accent-glow: rgba(138, 43, 226, 0.3);\n            --accent-hover: #9b42f5;\n            --yt-color: #ff0000;\n            --ig-color: #e1306c;\n            --tt-color: #00f2fe;\n            --x-color: #ffffff;\n            --fb-color: #1877f2;\n        }\n\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n\n        body {\n            font-family: 'Outfit', sans-serif;\n            background: var(--bg-gradient);\n            color: var(--text-primary);\n            min-height: 100vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            padding: 20px;\n            overflow-x: hidden;\n        }\n\n        .container {\n            width: 100%;\n            max-width: 1000px;\n            background: var(--card-bg);\n            border: 1px solid var(--card-border);\n            border-radius: 24px;\n            backdrop-filter: blur(20px);\n            -webkit-backdrop-filter: blur(20px);\n            padding: 40px;\n            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);\n            display: flex;\n            flex-direction: column;\n            gap: 30px;\n            transition: all 0.5s ease;\n        }\n\n        header {\n            text-align: center;\n        }\n\n        h1 {\n            font-size: 2.2rem;\n            font-weight: 700;\n            letter-spacing: -0.5px;\n            background: linear-gradient(to right, #fff, #b7a9f0);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            margin-bottom: 8px;\n        }\n\n        p.subtitle {\n            color: var(--text-secondary);\n            font-size: 1rem;\n        }\n\n        .content-grid {\n            display: grid;\n            grid-template-columns: 1.2fr 1fr;\n            gap: 40px;\n        }\n\n        @media (max-width: 850px) {\n            .content-grid {\n                grid-template-columns: 1fr;\n            }\n        }\n\n        .video-section {\n            display: flex;\n            flex-direction: column;\n            gap: 15px;\n        }\n\n        .video-wrapper {\n            position: relative;\n            width: 100%;\n            aspect-ratio: 16/9;\n            background: #000;\n            border-radius: 16px;\n            overflow: hidden;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n        }\n\n        video {\n            width: 100%;\n            height: 100%;\n            object-fit: contain;\n        }\n\n        .video-info {\n            background: rgba(0, 0, 0, 0.2);\n            border-radius: 12px;\n            padding: 15px;\n            font-size: 0.85rem;\n            color: var(--text-secondary);\n            border: 1px solid rgba(255, 255, 255, 0.03);\n            word-break: break-all;\n        }\n\n        .video-info strong {\n            color: var(--text-primary);\n        }\n\n        .form-section {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n\n        .input-group {\n            display: flex;\n            flex-direction: column;\n            gap: 8px;\n        }\n\n        label {\n            font-size: 0.9rem;\n            font-weight: 500;\n            color: var(--text-secondary);\n        }\n\n        input[type=\"text\"], textarea {\n            width: 100%;\n            background: rgba(0, 0, 0, 0.3);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            border-radius: 12px;\n            padding: 14px 16px;\n            color: #fff;\n            font-family: inherit;\n            font-size: 0.95rem;\n            transition: all 0.3s ease;\n        }\n\n        input[type=\"text\"]:focus, textarea:focus {\n            outline: none;\n            border-color: var(--accent-primary);\n            box-shadow: 0 0 10px var(--accent-glow);\n            background: rgba(0, 0, 0, 0.4);\n        }\n\n        textarea {\n            height: 120px;\n            resize: vertical;\n        }\n\n        .platforms-group {\n            display: flex;\n            flex-direction: column;\n            gap: 12px;\n        }\n\n        .platform-options {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));\n            gap: 10px;\n        }\n\n        .platform-card {\n            position: relative;\n            background: rgba(255, 255, 255, 0.02);\n            border: 1px solid rgba(255, 255, 255, 0.06);\n            border-radius: 12px;\n            padding: 12px;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            gap: 10px;\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n            user-select: none;\n        }\n\n        .platform-card:hover {\n            background: rgba(255, 255, 255, 0.05);\n            border-color: rgba(255, 255, 255, 0.15);\n            transform: translateY(-2px);\n        }\n\n        .platform-card input[type=\"checkbox\"] {\n            position: absolute;\n            opacity: 0;\n            cursor: pointer;\n            height: 0;\n            width: 0;\n        }\n\n        .platform-icon {\n            width: 20px;\n            height: 20px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            font-size: 0.85rem;\n            border-radius: 50%;\n            color: #fff;\n        }\n\n        .platform-card[data-platform=\"YouTube\"].active {\n            border-color: var(--yt-color);\n            box-shadow: 0 0 12px rgba(255, 0, 0, 0.2);\n            background: rgba(255, 0, 0, 0.05);\n        }\n        .platform-card[data-platform=\"YouTube\"] .platform-icon {\n            background: var(--yt-color);\n        }\n\n        .platform-card[data-platform=\"Instagram\"].active {\n            border-color: var(--ig-color);\n            box-shadow: 0 0 12px rgba(225, 48, 108, 0.2);\n            background: rgba(225, 48, 108, 0.05);\n        }\n        .platform-card[data-platform=\"Instagram\"] .platform-icon {\n            background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%,#d6249f 60%,#285AEB 90%);\n        }\n\n        .platform-card[data-platform=\"TikTok\"].active {\n            border-color: var(--tt-color);\n            box-shadow: 0 0 12px rgba(0, 242, 254, 0.2);\n            background: rgba(0, 242, 254, 0.05);\n        }\n        .platform-card[data-platform=\"TikTok\"] .platform-icon {\n            background: #010101;\n            border: 1px solid var(--tt-color);\n        }\n\n        .platform-card[data-platform=\"X (Twitter)\"].active {\n            border-color: var(--x-color);\n            box-shadow: 0 0 12px rgba(255, 255, 255, 0.2);\n            background: rgba(255, 255, 255, 0.05);\n        }\n        .platform-card[data-platform=\"X (Twitter)\"] .platform-icon {\n            background: #000;\n            border: 1px solid #fff;\n        }\n\n        .platform-card[data-platform=\"Facebook\"].active {\n            border-color: var(--fb-color);\n            box-shadow: 0 0 12px rgba(24, 119, 242, 0.2);\n            background: rgba(24, 119, 242, 0.05);\n        }\n        .platform-card[data-platform=\"Facebook\"] .platform-icon {\n            background: var(--fb-color);\n        }\n\n        .platform-name {\n            font-size: 0.85rem;\n            font-weight: 500;\n        }\n\n        .submit-btn {\n            background: var(--accent-primary);\n            color: #fff;\n            border: none;\n            border-radius: 12px;\n            padding: 16px;\n            font-family: inherit;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 10px;\n            box-shadow: 0 4px 15px var(--accent-glow);\n            margin-top: 10px;\n        }\n\n        .submit-btn:hover {\n            background: var(--accent-hover);\n            transform: translateY(-1px);\n            box-shadow: 0 6px 20px rgba(138, 43, 226, 0.5);\n        }\n\n        .submit-btn:active {\n            transform: translateY(1px);\n        }\n\n        .submit-btn:disabled {\n            background: rgba(255, 255, 255, 0.1);\n            color: rgba(255, 255, 255, 0.3);\n            box-shadow: none;\n            cursor: not-allowed;\n        }\n\n        .loading-spinner {\n            width: 20px;\n            height: 20px;\n            border: 2px solid rgba(255, 255, 255, 0.3);\n            border-radius: 50%;\n            border-top-color: #fff;\n            animation: spin 0.8s linear infinite;\n            display: none;\n        }\n\n        @keyframes spin {\n            to { transform: rotate(360deg); }\n        }\n\n        .success-state {\n            display: none;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            text-align: center;\n            padding: 40px 0;\n            gap: 20px;\n            animation: fadeIn 0.5s ease forwards;\n        }\n\n        .success-icon {\n            width: 80px;\n            height: 80px;\n            background: rgba(46, 213, 115, 0.1);\n            border: 1px solid rgb(46, 213, 115);\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: rgb(46, 213, 115);\n            font-size: 2.5rem;\n            box-shadow: 0 0 20px rgba(46, 213, 115, 0.2);\n        }\n\n        .success-title {\n            font-size: 1.8rem;\n            font-weight: 700;\n            color: #fff;\n        }\n\n        .success-desc {\n            color: var(--text-secondary);\n            max-width: 450px;\n            line-height: 1.6;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(10px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\" id=\"main-container\">\n        <header>\n            <h1>🎬 Social Media Upload Approval</h1>\n            <p class=\"subtitle\">Review your OBS recording and customize the metadata before publishing.</p>\n        </header>\n\n        <div class=\"content-grid\" id=\"workflow-content\">\n            <div class=\"video-section\">\n                <label>Video Preview</label>\n                <div class=\"video-wrapper\">\n                    <video id=\"video-player\" controls preload=\"metadata\">\n                        <source src=\"\" type=\"video/mp4\">\n                        Your browser does not support the video tag.\n                    </video>\n                </div>\n                <div class=\"video-info\">\n                    <strong>Source File:</strong> <span id=\"file-path-text\">C:\\path\\to\\video.mp4</span>\n                </div>\n            </div>\n\n            <div class=\"form-section\">\n                <form id=\"approval-form\">\n                    <input type=\"hidden\" id=\"video_path\" name=\"video_path\">\n\n                    <div class=\"input-group\">\n                        <label for=\"title\">Video Title</label>\n                        <input type=\"text\" id=\"title\" name=\"title\" required placeholder=\"Enter video title...\">\n                    </div>\n\n                    <div class=\"input-group\" style=\"margin-top: 15px;\">\n                        <label for=\"description\">Caption / Description</label>\n                        <textarea id=\"description\" name=\"description\" placeholder=\"Write a description or caption for your social posts...\"></textarea>\n                    </div>\n\n                    <div class=\"platforms-group\" style=\"margin-top: 20px;\">\n                        <label>Select Target Platforms</label>\n                        <div class=\"platform-options\">\n                            <label class=\"platform-card\" data-platform=\"YouTube\">\n                                <input type=\"checkbox\" name=\"platforms\" value=\"YouTube\">\n                                <div class=\"platform-icon\">Y</div>\n                                <span class=\"platform-name\">YouTube</span>\n                            </label>\n                            <label class=\"platform-card\" data-platform=\"Instagram\">\n                                <input type=\"checkbox\" name=\"platforms\" value=\"Instagram\">\n                                <div class=\"platform-icon\">I</div>\n                                <span class=\"platform-name\">Instagram</span>\n                            </label>\n                            <label class=\"platform-card\" data-platform=\"TikTok\">\n                                <input type=\"checkbox\" name=\"platforms\" value=\"TikTok\">\n                                <div class=\"platform-icon\">T</div>\n                                <span class=\"platform-name\">TikTok</span>\n                            </label>\n                            <label class=\"platform-card\" data-platform=\"X (Twitter)\">\n                                <input type=\"checkbox\" name=\"platforms\" value=\"X (Twitter)\">\n                                <div class=\"platform-icon\">X</div>\n                                <div style=\"display: flex; flex-direction: column; align-items: flex-start;\">\n                                    <span class=\"platform-name\">X (Twitter)</span>\n                                    <span style=\"font-size: 0.65rem; color: #ff9f43; font-weight: 500; margin-top: 1px;\">⚠️ Paid API Only</span>\n                                </div>\n                            </label>\n                            <label class=\"platform-card\" data-platform=\"Facebook\">\n                                <input type=\"checkbox\" name=\"platforms\" value=\"Facebook\">\n                                <div class=\"platform-icon\">F</div>\n                                <span class=\"platform-name\">Facebook</span>\n                            </label>\n                        </div>\n                    </div>\n\n                    <button type=\"submit\" class=\"submit-btn\" id=\"submit-btn\" style=\"width: 100%; margin-top: 25px;\">\n                        <div class=\"loading-spinner\" id=\"spinner\"></div>\n                        <span id=\"btn-text\">🚀 Approve & Publish</span>\n                    </button>\n                </form>\n            </div>\n        </div>\n\n        <div class=\"success-state\" id=\"success-screen\">\n            <div class=\"success-icon\">✓</div>\n            <h2 class=\"success-title\">Upload Pipeline Started</h2>\n            <p class=\"success-desc\">\n                Your video is now being processed and uploaded to the selected social platforms. \n                You can safely close this tab or return to OBS.\n            </p>\n        </div>\n    </div>\n\n    <script>\n        const urlParams = new URLSearchParams(window.location.search);\n        const rawVideoPath = urlParams.get('video_path') || '';\n        const rawTitle = urlParams.get('title') || '';\n\n        document.getElementById('video_path').value = rawVideoPath;\n        document.getElementById('file-path-text').textContent = rawVideoPath;\n        document.getElementById('title').value = rawTitle;\n\n        // Dynamically resolve webhook base path (handles /webhook-test/ and /webhook/ automatically)\n        const isTest = window.location.pathname.includes('/webhook-test/');\n        const webhookBase = isTest ? '/webhook-test/' : '/webhook/';\n\n        if (rawVideoPath) {\n            const encodedPath = encodeURIComponent(rawVideoPath);\n            const videoUrl = `${webhookBase}obs-stream-video?video_path=${encodedPath}`;\n            const videoPlayer = document.getElementById('video-player');\n            videoPlayer.querySelector('source').src = videoUrl;\n            videoPlayer.load();\n        }\n\n        const cards = document.querySelectorAll('.platform-card');\n        cards.forEach(card => {\n            const checkbox = card.querySelector('input[type=\"checkbox\"]');\n            \n            checkbox.addEventListener('change', () => {\n                if (checkbox.checked) {\n                    card.classList.add('active');\n                } else {\n                    card.classList.remove('active');\n                }\n                validateForm();\n            });\n            // Removed the custom click listener to prevent the double-toggling bug on label clicks\n        });\n\n        const submitBtn = document.getElementById('submit-btn');\n        function validateForm() {\n            const checkedPlatforms = document.querySelectorAll('input[name=\"platforms\"]:checked');\n            submitBtn.disabled = checkedPlatforms.length === 0;\n        }\n        \n        validateForm();\n\n        const form = document.getElementById('approval-form');\n        form.addEventListener('submit', async (e) => {\n            e.preventDefault();\n\n            const spinner = document.getElementById('spinner');\n            const btnText = document.getElementById('btn-text');\n            spinner.style.display = 'block';\n            btnText.textContent = 'Processing...';\n            submitBtn.disabled = true;\n\n            const selectedPlatforms = Array.from(document.querySelectorAll('input[name=\"platforms\"]:checked')).map(cb => cb.value);\n\n            const payload = {\n                video_path: document.getElementById('video_path').value,\n                title: document.getElementById('title').value,\n                description: document.getElementById('description').value,\n                platforms: selectedPlatforms\n            };\n\n            try {\n                const response = await fetch(`${webhookBase}obs-approve`, {\n                    method: 'POST',\n                    headers: {\n                        'Content-Type': 'application/json'\n                    },\n                    body: JSON.stringify(payload)\n                });\n\n                if (response.ok) {\n                    document.getElementById('workflow-content').style.display = 'none';\n                    document.getElementById('success-screen').style.display = 'flex';\n                } else {\n                    alert('Error starting upload pipeline. Please check n8n connections.');\n                    resetButton();\n                }\n            } catch (err) {\n                console.error(err);\n                alert('Connection to n8n server failed.');\n                resetButton();\n            }\n        });\n\n        function resetButton() {\n            const spinner = document.getElementById('spinner');\n            const btnText = document.getElementById('btn-text');\n            spinner.style.display = 'none';\n            btnText.textContent = '🚀 Approve & Publish';\n            submitBtn.disabled = false;\n            validateForm();\n        }\n</script>\n</body>\n</html>",
