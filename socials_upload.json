        "jsCode": "const winPath = $input.item.json.video_path || '';\nlet relativePath = winPath.replace(/\\\\/g, '/');\n\n// Extract the filename from the absolute path to make the workflow generic\nif (relativePath.match(/^[A-Za-z]:/)) {\n  relativePath = relativePath.split('/').pop();\n}\nrelativePath = relativePath.replace(/^\\//, '');\n\n$input.item.json.docker_path = `/recordings/${relativePath}`;\nreturn $input.item;"
